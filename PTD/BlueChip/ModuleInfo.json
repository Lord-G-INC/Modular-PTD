{
  "Name": "BlueChip",
  "Author": "Aurum",
  "Description": "Blue Star Chips",
  "InstallDependencies": ["Syati_ObjectFactories"],
  "SupportedGames": [
    "SB4E",
    "SB4P",
    "SB4J"
  ],
  "BuildTasks": [{
    "Task": "Copy",
    "From": "disc/",
    "To": "../../Output/disc/"
  }],
  "ModuleData" : [
    {
      "NameObjFactory" : [
        {
          "Name" : "BlueChip",
          "Function" : "createExtActor<pt::BlueChip>",
          "Include" : "BlueChip.h"
        },
        {
          "Name" : "BlueChipGroup",
          "Function" : "createExtActor<pt::BlueChipGroup>"
        }
      ]
    },
    {
      "SceneObjHolder" : [
        {
          "Name" : "0x6E",
          "Function" : "pt::createBlueChipHolder",
          "Include" : "BlueChip.h"
        }
      ]
    }
  ]
}